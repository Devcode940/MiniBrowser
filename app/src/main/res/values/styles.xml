<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Base theme is MaterialComponents (required by com.google.android.material:* deps).
      Existing browser Activities extend framework android.app.Activity; this theme
      works with them as well as with the new AppCompatActivity-based download UI.
    -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Material primary/secondary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/danger</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Window chrome -->
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:colorButtonNormal">@color/surface_elevated</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="ToolbarButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
        <item name="android:scaleType">center</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="ShortcutLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:singleLine">true</item>
    </style>

</resources>
