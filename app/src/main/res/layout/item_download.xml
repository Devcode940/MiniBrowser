<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/dl_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:singleLine="true"
        android:ellipsize="middle"
        tools:ignore="MissingDefaultResource"
        tools:text="stream.ts" />

    <TextView
        android:id="@+id/dl_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        tools:ignore="MissingDefaultResource"
        tools:text="12.3 MB / 45.0 MB" />

    <ProgressBar
        android:id="@+id/dl_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progressDrawable="@drawable/progress_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:layout_marginTop="4dp">

        <ImageButton
            android:id="@+id/dl_pause"
            style="@style/ToolbarButton"
            android:src="@drawable/ic_pause"
            android:contentDescription="@string/download_pause" />

        <ImageButton
            android:id="@+id/dl_open"
            style="@style/ToolbarButton"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/download_open"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/dl_share"
            style="@style/ToolbarButton"
            android:src="@drawable/ic_share"
            android:contentDescription="@string/download_share"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/dl_delete"
            style="@style/ToolbarButton"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/download_delete" />
    </LinearLayout>
</LinearLayout>
