<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <!-- ============ MAIN COLUMN ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== Top toolbar ===== -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/primary"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_back"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/cd_back" />

            <ImageButton
                android:id="@+id/btn_forward"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_forward"
                android:contentDescription="@string/cd_forward" />

            <EditText
                android:id="@+id/url_bar"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:paddingStart="14dp"
                android:paddingEnd="30dp"
                android:background="@drawable/url_bar_bg"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/search_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:imeOptions="actionGo"
                android:inputType="textUri|textNoSuggestions"
                android:selectable="true"
                android:textIsSelectable="true" />

            <ImageButton
                android:id="@+id/btn_bookmark"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_bookmark_outline"
                android:contentDescription="@string/cd_bookmark" />

            <ImageButton
                android:id="@+id/btn_reload"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_reload"
                android:contentDescription="@string/cd_reload" />

            <ImageButton
                android:id="@+id/btn_menu"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/cd_menu" />
        </LinearLayout>

        <!-- ===== Slim progress ===== -->
        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progressDrawable="@drawable/progress_bar"
            android:visibility="gone" />

        <!-- ===== WebView ===== -->
        <com.minibrowser.GestureWebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- ============ HOMEPAGE OVERLAY ============ -->
    <ScrollView
        android:id="@+id/home_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/toolbar_height"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="34sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="privacy-first · zero-telemetry"
                android:textColor="@color/accent"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/home_search"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="28dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/url_bar_bg"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="10dp"
                android:hint="@string/search_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="textUri|textNoSuggestions" />

            <GridLayout
                android:id="@+id/shortcut_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:columnCount="4"
                android:rowCount="3"
                android:useDefaultMargins="true" />
        </LinearLayout>
    </ScrollView>

    <!-- ============ BOTTOM SHEET (3 pages) ============ -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_bg"
        android:elevation="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/sheet_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/sheet_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/page_privacy"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/sheet_prev"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_back"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/sheet_next"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_forward"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/sheet_close"
                style="@style/ToolbarButton"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/cd_close" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider" />

        <FrameLayout
            android:id="@+id/sheet_pages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp" />

        <!-- Pager dots -->
        <LinearLayout
            android:id="@+id/sheet_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="14dp">
            <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="5dp" android:background="@drawable/dot_active" />
            <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="5dp" android:background="@drawable/dot_inactive" />
            <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="5dp" android:background="@drawable/dot_inactive" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
